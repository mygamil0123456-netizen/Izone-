{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User profile with role-based access",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "fullName": { "type": "string" },
        "phone": { "type": "string" },
        "role": { "type": "string", "enum": ["customer", "admin", "agent"] },
        "location": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Product": {
      "title": "Product",
      "description": "Product details",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "discountPrice": { "type": "number" },
        "images": { "type": "array", "items": { "type": "string" } },
        "category": { "type": "string" },
        "stock": { "type": "integer" },
        "ratings": { "type": "number" },
        "reviewCount": { "type": "integer" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price", "category", "stock"]
    },
    "Order": {
      "title": "Order",
      "description": "Customer order details",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "items": { "type": "array", "items": { "type": "object" } },
        "totalAmount": { "type": "number" },
        "address": { "type": "string" },
        "phone": { "type": "string" },
        "paymentMethod": { "type": "string", "enum": ["bkash", "nagad", "rocket", "card", "cod"] },
        "paymentStatus": { "type": "string", "enum": ["pending", "paid", "failed"] },
        "status": { "type": "string", "enum": ["pending", "approved", "processing", "shipped", "delivered", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "items", "totalAmount", "address", "phone", "paymentMethod", "status"]
    },
    "Review": {
      "title": "Review",
      "description": "Product review from customer",
      "type": "object",
      "properties": {
        "productId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "rating": { "type": "integer" },
        "comment": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["productId", "userId", "rating", "comment"]
    },
    "SupportTicket": {
      "title": "Support Ticket",
      "description": "Customer support interaction",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "agentId": { "type": "string" },
        "subject": { "type": "string" },
        "status": { "type": "string", "enum": ["open", "assigned", "resolved", "closed"] },
        "messages": { "type": "array", "items": { "type": "object" } },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "subject", "status"]
    }
  },
  "firestore": {
    "users": {
      "schema": "User",
      "description": "User profiles"
    },
    "products": {
      "schema": "Product",
      "description": "Product catalog"
    },
    "orders": {
      "schema": "Order",
      "description": "Order history"
    },
    "products/{productId}/reviews": {
      "schema": "Review",
      "description": "Reviews for a product"
    },
    "support_tickets": {
      "schema": "SupportTicket",
      "description": "Support chat and tickets"
    }
  }
}
